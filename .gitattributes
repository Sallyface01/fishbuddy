# Binary files — prevent Git from corrupting them with line-ending conversion
*.jar  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gz   binary
*.zip  binary

# Shell scripts must use LF
*.sh   text eol=lf
gradlew text eol=lf

# Batch scripts must use CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Kotlin/Gradle files
*.kt   text eol=lf
*.kts  text eol=lf
*.xml  text eol=lf
*.properties text eol=lf
